# Copy this file to .env and fill in real values locally.
# Never commit .env.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=
OPENAI_API_KEY=

# Hugging Face model repos:
# 1. `hf auth login` on this machine, or
# 2. HF_TOKEN set in the environment.
HF_SLANG_DETECTOR_REPO=GabCaiado/english-app-slang-detector
HF_SLANG_SENSE_CLASSIFIER_REPO=GabCaiado/english-app-slang-sense-classifier
HF_SLANG_NORMALIZER_REPO=GabCaiado/english-app-slang-normalizer-v4-1-small
HF_MODEL_REVISION=main
